<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Segment-specific configuration per product. THIS IS THE SCALABILITY LAYER. Same product can serve SB, Individual, and Large Group through different selling models.</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableHistory>true</enableHistory>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>Selling Model</label>
    <nameField><displayFormat>SM-{00000}</displayFormat><label>Model ID</label><type>AutoNumber</type></nameField>
    <pluralLabel>Selling Models</pluralLabel>
    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
</CustomObject>